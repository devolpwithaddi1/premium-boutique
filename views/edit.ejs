<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Product</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Edit Product ✏️</h1>
    
    <div class="product-card" style="max-width: 500px; margin: auto;">
        <form action="/admin/edit/<%= product.id %>" method="POST">
            <label>Name:</label>
            <input type="text" name="name" value="<%= product.name %>" required style="width: 90%; padding: 10px; margin-bottom: 10px;">
            
            <label>Price (KSh):</label>
            <input type="number" name="price" value="<%= product.price %>" required style="width: 90%; padding: 10px; margin-bottom: 10px;">
            
            <label>Category:</label>
            <input type="text" name="category" value="<%= product.category %>" style="width: 90%; padding: 10px; margin-bottom: 10px;">
            
            <label>Stock:</label>
            <input type="number" name="stock" value="<%= product.stock %>" required style="width: 90%; padding: 10px; margin-bottom: 15px;">
            
            <button type="submit" style="width: 100%; background-color: #f39c12;">Save Changes</button>
        </form>
        
        <div style="text-align: center; margin-top: 15px;">
            <a href="/admin" style="color: #666; text-decoration: none;">Cancel</a>
        </div>
    </div>
</body>
</html>