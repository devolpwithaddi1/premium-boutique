<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Customer Orders</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Business Orders Dashboard 📊</h1>
    
    <div style="max-width: 800px; margin: auto;">
        <% if (orders.length === 0) { %>
            <p style="text-align: center;">You don't have any orders yet. Time to market those bags!</p>
        <% } else { %>
            <% orders.forEach(function(order) { %>
                <div class="product-card" style="text-align: left; margin-bottom: 20px; border-left: 5px solid #27ae60;">
                    <h3>Order #<%= order.id %></h3>
                    <p><strong>Customer:</strong> <%= order.customer_name %> (<%= order.contact %>)</p>
                    <p><strong>Items Bought:</strong> <%= order.items %></p>
                    <p><strong>Total Amount:</strong> <span class="price">KSh <%= order.total_price %></span></p>
                    <p style="font-size: 0.8rem; color: gray;">Date: <%= order.order_date %></p>
                </div>
            <% }); %>
        <% } %>
    </div>

    <div style="text-align: center; margin-top: 30px;">
        <a href="/admin" style="margin-right: 20px; color: #333; text-decoration: none;">⬅ Add New Products</a>
        <a href="/" style="color: #333; text-decoration: none;">🏠 View Storefront</a>
    </div>
    <a href="/logout">Logout</a>
</body>
</html>