<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><title>Checkout</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Finalize Your Order</h1>
    <div class="product-card" style="max-width: 400px; margin: auto;">
        <h3>Order Total: KSh <%= total %></h3>
        <form action="/place-order" method="POST">
    <input type="text" name="name" placeholder="Full Name" required style="width: 90%; padding: 10px; margin-bottom: 10px;">
    
    <label style="display: block; font-size: 0.9rem; color: #555; margin-bottom: 5px;">M-Pesa Phone Number (Format: 2547...)</label>
    <input type="number" name="phone" placeholder="254712345678" required style="width: 90%; padding: 10px; margin-bottom: 15px;">
    
    <button type="submit" style="width: 100%; background-color: #27ae60;">Pay with M-Pesa</button>
</form>
    </div>
</body>
</html>