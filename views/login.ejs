<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Login</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Boutique Login 🔐</h1>
    
    <div class="product-card" style="max-width: 400px; margin: auto;">
        <% if (error) { %>
            <p style="color: red; text-align: center;"><%= error %></p>
        <% } %>

        <form action="/login" method="POST">
            <input type="text" name="username" placeholder="Username" required style="width: 90%; padding: 10px; margin-bottom: 15px;">
            <input type="password" name="password" placeholder="Password" required style="width: 90%; padding: 10px; margin-bottom: 15px;">
            <button type="submit" style="width: 100%; background-color: #333;">Login to Dashboard</button>
        </form>
    </div>
    
    <div style="text-align: center; margin-top: 20px;">
        <a href="/" style="color: #333;">⬅ Back to Storefront</a>
    </div>
</body>
</html>